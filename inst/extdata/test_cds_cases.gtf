## CDS: 25000-25900 (all CDS)
## SE event on exon2: 91bp overlap with CDS, 91%%3=1 → frame-disrupting
chrT	test	gene	25000	25900	.	+	.	gene_id "GENE_FD_D2"; gene_name "FD_D2";
chrT	test	transcript	25000	25900	.	+	.	gene_id "GENE_FD_D2"; transcript_id "TX_D2_ref"; gene_name "FD_D2";
