##description: Synthetic CDS test cases for Isopair Phase 3
##provider: Isopair test suite
## Group A: Region classification (+ strand)
## Group C: PTC distances (+ strand)
## Group D: Frame disruption (+ strand)
## Group F: Minus strand mirrors
## Group G: Edge cases
##
## ========================================================================
## GROUP A: Region classification (+ strand)
## ========================================================================
##
## GENE_CDS_A1: 3-exon, CDS spans all 3 exons fully
## Exon1: 1000-1200, Exon2: 1500-1800, Exon3: 2100-2400
## CDS: 1000-2400 (all exonic bases are CDS)
## Expected: all union exon segments → "CDS"
chrT	test	gene	1000	2400	.	+	.	gene_id "GENE_CDS_A1"; gene_name "CDS_A1";
chrT	test	transcript	1000	2400	.	+	.	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; gene_name "CDS_A1";
chrT	test	exon	1000	1200	.	+	.	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "1";
chrT	test	exon	1500	1800	.	+	.	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "2";
chrT	test	exon	2100	2400	.	+	.	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "3";
chrT	test	CDS	1000	1200	.	+	0	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "1";
chrT	test	CDS	1500	1800	.	+	0	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "2";
chrT	test	CDS	2100	2400	.	+	0	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1"; exon_number "3";
chrT	test	start_codon	1000	1002	.	+	0	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1";
chrT	test	stop_codon	2398	2400	.	+	0	gene_id "GENE_CDS_A1"; transcript_id "TX_A1_1";
##
## GENE_CDS_A2: 3-exon, CDS only in exon 2
## Exon1: 3000-3200 (5'UTR), Exon2: 3500-3800 (contains_orf_start_stop), Exon3: 4100-4300 (3'UTR)
## CDS: 3550-3750
chrT	test	gene	3000	4300	.	+	.	gene_id "GENE_CDS_A2"; gene_name "CDS_A2";
chrT	test	transcript	3000	4300	.	+	.	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1"; gene_name "CDS_A2";
chrT	test	exon	3000	3200	.	+	.	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1"; exon_number "1";
chrT	test	exon	3500	3800	.	+	.	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1"; exon_number "2";
chrT	test	exon	4100	4300	.	+	.	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1"; exon_number "3";
chrT	test	CDS	3550	3750	.	+	0	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1"; exon_number "2";
chrT	test	start_codon	3550	3552	.	+	0	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1";
chrT	test	stop_codon	3748	3750	.	+	0	gene_id "GENE_CDS_A2"; transcript_id "TX_A2_1";
##
## GENE_CDS_A3: 3-exon, CDS starts mid-exon1, ends mid-exon3
## Exon1: 5000-5300, Exon2: 5600-5900, Exon3: 6200-6500
## CDS: 5100-6350
## Exon1: contains_orf_start (5000-5300 spans 5100)
## Exon2: CDS (entirely within 5100-6350)
## Exon3: contains_orf_stop (6200-6500 spans 6350)
chrT	test	gene	5000	6500	.	+	.	gene_id "GENE_CDS_A3"; gene_name "CDS_A3";
chrT	test	transcript	5000	6500	.	+	.	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; gene_name "CDS_A3";
chrT	test	exon	5000	5300	.	+	.	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "1";
chrT	test	exon	5600	5900	.	+	.	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "2";
chrT	test	exon	6200	6500	.	+	.	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "3";
chrT	test	CDS	5100	5300	.	+	0	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "1";
chrT	test	CDS	5600	5900	.	+	0	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "2";
chrT	test	CDS	6200	6350	.	+	0	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1"; exon_number "3";
chrT	test	start_codon	5100	5102	.	+	0	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1";
chrT	test	stop_codon	6348	6350	.	+	0	gene_id "GENE_CDS_A3"; transcript_id "TX_A3_1";
##
## GENE_CDS_A4: 1-exon, CDS within single exon
## Exon1: 7000-7600
## CDS: 7100-7500 → contains_orf_start_stop
chrT	test	gene	7000	7600	.	+	.	gene_id "GENE_CDS_A4"; gene_name "CDS_A4";
chrT	test	transcript	7000	7600	.	+	.	gene_id "GENE_CDS_A4"; transcript_id "TX_A4_1"; gene_name "CDS_A4";
chrT	test	exon	7000	7600	.	+	.	gene_id "GENE_CDS_A4"; transcript_id "TX_A4_1"; exon_number "1";
chrT	test	CDS	7100	7500	.	+	0	gene_id "GENE_CDS_A4"; transcript_id "TX_A4_1"; exon_number "1";
chrT	test	start_codon	7100	7102	.	+	0	gene_id "GENE_CDS_A4"; transcript_id "TX_A4_1";
chrT	test	stop_codon	7498	7500	.	+	0	gene_id "GENE_CDS_A4"; transcript_id "TX_A4_1";
##
## ========================================================================
## GROUP C: PTC distances (+ strand)
## ========================================================================
##
## GENE_PTC_C1: 3-exon, stop 100nt before last EJC → has_ptc=TRUE
## Exon1: 10000-10300 (301bp), Exon2: 10600-10900 (301bp), Exon3: 11200-11500 (301bp)
## Total mRNA = 903bp. Last EJC at mRNA pos 602 (301+301).
## Stop at mRNA pos 502 → ptc_distance = 602-502 = 100
## For + strand, stop_pos = cds_stop. Exon2 start = 10600, offset = stop_pos - 10600
## mRNA pos = 301 + offset. We need 301 + offset = 502, so offset = 201
## stop_pos = 10600 + 201 = 10801
## CDS: 10000-10801
chrT	test	gene	10000	11500	.	+	.	gene_id "GENE_PTC_C1"; gene_name "PTC_C1";
chrT	test	transcript	10000	11500	.	+	.	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; gene_name "PTC_C1";
chrT	test	exon	10000	10300	.	+	.	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; exon_number "1";
chrT	test	exon	10600	10900	.	+	.	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; exon_number "2";
chrT	test	exon	11200	11500	.	+	.	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; exon_number "3";
chrT	test	CDS	10000	10300	.	+	0	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; exon_number "1";
chrT	test	CDS	10600	10801	.	+	0	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1"; exon_number "2";
chrT	test	start_codon	10000	10002	.	+	0	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1";
chrT	test	stop_codon	10799	10801	.	+	0	gene_id "GENE_PTC_C1"; transcript_id "TX_C1_1";
##
## GENE_PTC_C2: 3-exon, stop 30nt before last EJC → has_ptc=FALSE
## Same exon structure as C1. Last EJC at mRNA 602.
## Stop at mRNA 572 → ptc_distance = 602-572 = 30
## offset = 572-301 = 271, stop_pos = 10600+271 = 10871
## CDS: 10000-10871
chrT	test	gene	13000	14500	.	+	.	gene_id "GENE_PTC_C2"; gene_name "PTC_C2";
chrT	test	transcript	13000	14500	.	+	.	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; gene_name "PTC_C2";
chrT	test	exon	13000	13300	.	+	.	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; exon_number "1";
chrT	test	exon	13600	13900	.	+	.	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; exon_number "2";
chrT	test	exon	14200	14500	.	+	.	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; exon_number "3";
chrT	test	CDS	13000	13300	.	+	0	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; exon_number "1";
chrT	test	CDS	13600	13871	.	+	0	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1"; exon_number "2";
chrT	test	start_codon	13000	13002	.	+	0	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1";
chrT	test	stop_codon	13869	13871	.	+	0	gene_id "GENE_PTC_C2"; transcript_id "TX_C2_1";
##
## GENE_PTC_C3: 3-exon, stop in last exon → stop_in_last_exon=TRUE, has_ptc=FALSE
## Exon1: 16000-16300 (301bp), Exon2: 16600-16900 (301bp), Exon3: 17200-17500 (301bp)
## CDS extends into last exon. Stop in exon 3 at 17300.
## Last EJC at mRNA 602. Stop at mRNA = 301+301+(17300-17200) = 702 → ptc_distance = 602-702 = -100
chrT	test	gene	16000	17500	.	+	.	gene_id "GENE_PTC_C3"; gene_name "PTC_C3";
chrT	test	transcript	16000	17500	.	+	.	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; gene_name "PTC_C3";
chrT	test	exon	16000	16300	.	+	.	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "1";
chrT	test	exon	16600	16900	.	+	.	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "2";
chrT	test	exon	17200	17500	.	+	.	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "3";
chrT	test	CDS	16000	16300	.	+	0	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "1";
chrT	test	CDS	16600	16900	.	+	0	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "2";
chrT	test	CDS	17200	17300	.	+	0	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1"; exon_number "3";
chrT	test	start_codon	16000	16002	.	+	0	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1";
chrT	test	stop_codon	17298	17300	.	+	0	gene_id "GENE_PTC_C3"; transcript_id "TX_C3_1";
##
## GENE_PTC_C4: 1-exon, coding → single-exon, has_ptc=FALSE
## Exon1: 19000-19600
## CDS: 19100-19500
chrT	test	gene	19000	19600	.	+	.	gene_id "GENE_PTC_C4"; gene_name "PTC_C4";
chrT	test	transcript	19000	19600	.	+	.	gene_id "GENE_PTC_C4"; transcript_id "TX_C4_1"; gene_name "PTC_C4";
chrT	test	exon	19000	19600	.	+	.	gene_id "GENE_PTC_C4"; transcript_id "TX_C4_1"; exon_number "1";
chrT	test	CDS	19100	19500	.	+	0	gene_id "GENE_PTC_C4"; transcript_id "TX_C4_1"; exon_number "1";
chrT	test	start_codon	19100	19102	.	+	0	gene_id "GENE_PTC_C4"; transcript_id "TX_C4_1";
chrT	test	stop_codon	19498	19500	.	+	0	gene_id "GENE_PTC_C4"; transcript_id "TX_C4_1";
##
## ========================================================================
## GROUP D: Frame disruption (+ strand)
## ========================================================================
##
## GENE_FD_D1: SE event, 90bp CDS overlap (90%%3=0) → frame_disrupting=FALSE
## Reference TX_D1_ref: 3 exons (has the SE)
## Comparator TX_D1_comp: 2 exons (skips exon 2)
## Exon1: 22000-22200, Exon2: 22400-22489 (90bp), Exon3: 22700-22900
## CDS: 22000-22900 (all CDS)
## SE event on exon2: 90bp overlap with CDS, 90%%3=0 → NOT frame-disrupting
chrT	test	gene	22000	22900	.	+	.	gene_id "GENE_FD_D1"; gene_name "FD_D1";
chrT	test	transcript	22000	22900	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; gene_name "FD_D1";
chrT	test	exon	22000	22200	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "1";
chrT	test	exon	22400	22489	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "2";
chrT	test	exon	22700	22900	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "3";
chrT	test	CDS	22000	22200	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "1";
chrT	test	CDS	22400	22489	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "2";
chrT	test	CDS	22700	22900	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref"; exon_number "3";
chrT	test	start_codon	22000	22002	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref";
chrT	test	stop_codon	22898	22900	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_ref";
chrT	test	transcript	22000	22900	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_comp"; gene_name "FD_D1";
chrT	test	exon	22000	22200	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_comp"; exon_number "1";
chrT	test	exon	22700	22900	.	+	.	gene_id "GENE_FD_D1"; transcript_id "TX_D1_comp"; exon_number "2";
chrT	test	CDS	22000	22200	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_comp"; exon_number "1";
