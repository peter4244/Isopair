##
## ========================================================================
## GROUP F: Minus strand mirrors
## ========================================================================
##
## GENE_CDS_F1: Mirror of A3 on - strand
## Exon1: 31000-31300, Exon2: 31600-31900, Exon3: 32200-32500
## On - strand: 5'→3' = descending genomic (exon3→exon2→exon1)
## CDS: 31100-32350
## Exon3 (first bio): contains_orf_start (31100 not within 32200-32500, but cds_start is in exon1)
## Wait, for - strand: biological stop = cds_start (lower coord), biological start = cds_stop (higher coord)
## So: cds_start=31100, cds_stop=32350
## Exon3 (32200-32500): spans cds_stop=32350 → contains_orf_start (bio start on - strand)
## Exon2 (31600-31900): entirely within 31100-32350 → CDS
## Exon1 (31000-31300): spans cds_start=31100 → contains_orf_stop (bio stop on - strand)
## But region classification is strand-independent per the pipeline (uses genomic coords)
## The label "contains_orf_start" = spans cds_start, "contains_orf_stop" = spans cds_stop
chrT	test	gene	31000	32500	.	-	.	gene_id "GENE_CDS_F1"; gene_name "CDS_F1";
chrT	test	transcript	31000	32500	.	-	.	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; gene_name "CDS_F1";
chrT	test	exon	31000	31300	.	-	.	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "3";
chrT	test	exon	31600	31900	.	-	.	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "2";
chrT	test	exon	32200	32500	.	-	.	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "1";
chrT	test	CDS	31100	31300	.	-	0	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "3";
chrT	test	CDS	31600	31900	.	-	0	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "2";
chrT	test	CDS	32200	32350	.	-	0	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1"; exon_number "1";
chrT	test	start_codon	32348	32350	.	-	0	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1";
chrT	test	stop_codon	31100	31102	.	-	0	gene_id "GENE_CDS_F1"; transcript_id "TX_F1_1";
##
## GENE_PTC_F2: Mirror of C1 on - strand (PTC distance=100, has_ptc=TRUE)
## Exon1: 35000-35300 (301bp), Exon2: 35600-35900 (301bp), Exon3: 36200-36500 (301bp)
## On - strand: bio order is exon3(first), exon2, exon1(last)
## Last EJC in mRNA = sum of first two bio exons = 301+301 = 602
## Stop at mRNA 502 → ptc_distance = 100
## Bio stop = cds_start (lower coord on - strand)
## Bio order: exon3(36200-36500), exon2(35600-35900), exon1(35000-35300)
## Stop in exon2: offset = e_ends[exon2_idx] - stop_pos = 35900 - stop_pos
## mRNA = 301 + offset. Need 301+offset=502, offset=201, stop_pos = 35900-201 = 35699
## CDS: cds_start = 35699 (bio stop), cds_stop = 36500 (bio start)
chrT	test	gene	35000	36500	.	-	.	gene_id "GENE_PTC_F2"; gene_name "PTC_F2";
chrT	test	transcript	35000	36500	.	-	.	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; gene_name "PTC_F2";
chrT	test	exon	35000	35300	.	-	.	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; exon_number "3";
chrT	test	exon	35600	35900	.	-	.	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; exon_number "2";
chrT	test	exon	36200	36500	.	-	.	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; exon_number "1";
chrT	test	CDS	35699	35900	.	-	0	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; exon_number "2";
chrT	test	CDS	36200	36500	.	-	0	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1"; exon_number "1";
chrT	test	start_codon	36498	36500	.	-	0	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1";
chrT	test	stop_codon	35699	35701	.	-	0	gene_id "GENE_PTC_F2"; transcript_id "TX_F2_1";
