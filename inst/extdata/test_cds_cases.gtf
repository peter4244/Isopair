chrT	test	stop_codon	25898	25900	.	+	0	gene_id "GENE_FD_D2"; transcript_id "TX_D2_ref";
chrT	test	transcript	25000	25900	.	+	.	gene_id "GENE_FD_D2"; transcript_id "TX_D2_comp"; gene_name "FD_D2";
chrT	test	exon	25000	25200	.	+	.	gene_id "GENE_FD_D2"; transcript_id "TX_D2_comp"; exon_number "1";
chrT	test	exon	25700	25900	.	+	.	gene_id "GENE_FD_D2"; transcript_id "TX_D2_comp"; exon_number "2";
chrT	test	CDS	25000	25200	.	+	0	gene_id "GENE_FD_D2"; transcript_id "TX_D2_comp"; exon_number "1";
