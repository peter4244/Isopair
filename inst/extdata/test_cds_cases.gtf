chrT	test	stop_codon	22898	22900	.	+	0	gene_id "GENE_FD_D1"; transcript_id "TX_D1_comp";
##
## GENE_FD_D2: SE event, 91bp CDS overlap (91%%3=1) → frame_disrupting=TRUE
## Reference TX_D2_ref: 3 exons (has the SE)
## Comparator TX_D2_comp: 2 exons (skips exon 2)
