chrT	test	gene	28000	28500	.	+	.	gene_id "GENE_FD_D3"; gene_name "FD_D3";
chrT	test	transcript	28000	28500	.	+	.	gene_id "GENE_FD_D3"; transcript_id "TX_D3_ref"; gene_name "FD_D3";
